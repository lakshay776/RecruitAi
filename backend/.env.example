# ── Groq Configuration ────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
# Retry policy for transient Groq failures (rate limits, 5xx, timeouts)
GROQ_MAX_RETRIES=3
GROQ_RETRY_BASE_DELAY=1.0

# ── Processing Limits ─────────────────────────────────────────────────────────
MAX_CVS_PER_BATCH=50
TOP_N_CANDIDATES=10
PROCESSING_TIMEOUT_SECONDS=120

# How long (seconds) a job's state is kept in the in-memory store after its
# last activity, before being evicted. Set to 0 to disable eviction.
JOB_RETENTION_SECONDS=3600
